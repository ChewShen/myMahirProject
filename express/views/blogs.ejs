<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Styles -->
    <link rel="stylesheet" href="/css/header.css" />

    <title><%= title %></title>
  </head>
  <body>
    <div class="header">
      <h1><%= title %></h1>
     
    </div>

    <!-- Next Code Here -->
     <div style="display: flex; justify-content: center">
        <ul>
        <% posts.forEach(function(post){ %>
            <li>
            <a href="/blogs/post/<%= post.id %>">
                <%= post.title %>
            </a>
            </li>
        <% }); %>
        </ul>
    </div>
  </body>
</html>
